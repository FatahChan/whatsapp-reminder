{
	"name": "whatsapp-reminder",
	"version": "0.1.0",
	"description": "WhatsApp Reminder — desktop scheduled messages (Electrobun + React + whatsapp-web.js)",
	"repository": {
		"type": "git",
		"url": "https://github.com/FatahChan/whatsapp-reminder.git"
	},
	"scripts": {
		"dev": "concurrently \"bun run hmr\" \"bun run scripts/electrobun-after-vite.ts\"",
		"hmr": "vite --port 5173",
		"build": "vite build && electrobun build --env=canary",
		"bundle": "bun run scripts/build-bundle.ts",
		"build:web": "vite build",
		"build:desktop": "electrobun build --env=canary"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@tanstack/react-router": "^1.168.10",
		"@tanstack/react-router-devtools": "^1.166.11",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electrobun": "1.16.0",
		"lowdb": "^7.0.1",
		"lucide-react": "^1.7.0",
		"node-cron": "^4.2.1",
		"qrcode": "^1.5.4",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.5.0",
		"whatsapp-web.js": "^1.34.6"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/router-plugin": "^1.167.12",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.2",
		"@types/node-cron": "^3.0.11",
		"@types/qrcode": "^1.5.6",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/three": "^0.183.1",
		"@vitejs/plugin-react": "^6.0.1",
		"concurrently": "^9.2.1",
		"shadcn": "^4.1.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.3"
	}
}
